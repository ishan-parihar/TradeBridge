# Configure path to MT5 terminal (Bottles/Wine)
MT5_TERMINAL_PATH="/home/ishanp/.local/share/bottles/bottles/Apps/drive_c/Program Files/MetaTrader 5"

# Runtime adapter: pymt5 | ea_socket
MT5_ADAPTER=pymt5

# Environment: paper | demo | live
MT5_ENV=demo

# Execution mode per PLAN (writes disabled until policy/approval wired)
MT5_EXECUTION_MODE=human_approval_required

# MT5 Broker Credentials (for Docker MT5 terminal — set before deploy)
MT5_BROKER_LOGIN=
MT5_BROKER_PASSWORD=
MT5_BROKER_SERVER=MetaQuotes-Demo

# Vibe-Trading Integration (optional — for research/strategy/backtesting)
VIBE_TRADING_DIR=../Vibe-Trading/agent
VIBE_TRADING_MCP_PORT=8900
VIBE_TRADING_LLM_PROVIDER=ollama
VIBE_TRADING_LLM_BASE_URL=http://localhost:11434
VIBE_TRADING_LLM_MODEL=deepseek-r1:latest
VIBE_TRADING_AUTO_START=false
